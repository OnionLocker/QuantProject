# .env.example - 复制为 .env 并填写真实值
# cp .env.example .env

# ── Telegram 通知（必填）────────────────────────────────────────────────────
# 通过 @BotFather 创建 Bot 获得 Token
TG_BOT_TOKEN=your_telegram_bot_token_here
# 你的 Telegram Chat ID（用 @userinfobot 查询）
TG_CHAT_ID=your_chat_id_here

# ── 安全密钥（首次 deploy.sh 自动生成，无需手填）────────────────────────────
# OKX API Key 加密密钥（Fernet，deploy.sh 自动写入）
# ENCRYPT_KEY=

# JWT 签名密钥（deploy.sh 自动写入）
# JWT_SECRET=

# ── 可选：单用户模式 OKX API（main.py 直接跑时使用）─────────────────────────
# 多用户 Web 版不需要填这里，通过网页界面配置
# OKX_API_KEY=
# OKX_SECRET_KEY=
# OKX_PASSPHRASE=

# 模拟盘（填了下面这三个则自动切换模拟盘）
# SIMULATE_OKX_API_KEY=
# SIMULATE_OKX_SECRET_KEY=
# SIMULATE_OKX_PASSPHRASE=
