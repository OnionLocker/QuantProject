# .env.example - 复制为 .env 并填写真实值
# cp .env.example .env
# chmod 600 .env   # 限制文件权限（deploy.sh 自动执行）

# ── 运行环境 ──────────────────────────────────────────────────────────────────
# development: 启用 API docs (/api/docs)、宽松日志
# production:  禁用 docs、启用安全检查（默认）
# QUANTBOT_ENV=production

# ── Telegram 通知（必填）────────────────────────────────────────────────────
# 通过 @BotFather 创建 Bot 获得 Token
TG_BOT_TOKEN=your_telegram_bot_token_here
# 你的 Telegram Chat ID（用 @userinfobot 查询）
TG_CHAT_ID=your_chat_id_here

# ── 安全密钥（首次 deploy.sh 自动生成，无需手填）────────────────────────────
# OKX API Key 加密密钥（Fernet，deploy.sh 自动写入）
# ENCRYPT_KEY=

# JWT 签名密钥（deploy.sh 自动写入，建议至少 32 字符随机字符串）
# 生成命令：python3 -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET=

# ── AI 情绪分析（可选）──────────────────────────────────────────────────────
# 支持 OpenAI / DeepSeek / 零一万物等 OpenAI 兼容接口
# 填入后自动启用 AI 新闻情绪分析
# AI_API_KEY=your_openai_or_deepseek_api_key
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# ── 可选：单用户模式 OKX API（main.py 直接跑时使用）─────────────────────────
# 多用户 Web 版不需要填这里，通过网页界面配置
# OKX_API_KEY=
# OKX_SECRET_KEY=
# OKX_PASSPHRASE=

# 模拟盘（填了下面这三个则自动切换模拟盘）
# SIMULATE_OKX_API_KEY=
# SIMULATE_OKX_SECRET_KEY=
# SIMULATE_OKX_PASSPHRASE=
